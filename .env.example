# Path to the Firebase service account JSON file (not committed).
# Download from: Firebase Console → Project settings → Service accounts → Generate new private key
# Recommended location: config/firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=./config/firebase-service-account.json

# Alternative name (same purpose); ignored if GOOGLE_APPLICATION_CREDENTIALS is set.
# FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Vertex AI (Gemini) — same GCP project as Firebase is fine
# Enable: https://console.cloud.google.com/apis/library/aiplatform.googleapis.com
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1
# Optional: override default (code uses gemini-2.5-flash). 1.5 models are retired on Vertex.
# GEMINI_MODEL=gemini-2.0-flash-001

# Log Vertex/Gemini errors in the server terminal (debugging). Remove or set to 0 in production.
GEMINI_DEBUG=1

# Base URL for Core API (POST /events). Defaults to local server.
# API_BASE_URL=http://127.0.0.1:3000

# Mapbox GL (frontend map). Create a token at https://account.mapbox.com/access-tokens/
# Vite loads env from the repo root (see frontend/vite.config.ts envDir).
# VITE_MAPBOX_TOKEN=pk.ey...

# Bulk import from data/scraped_posts.json (npm run import:scraped)
# Writes Firestore directly by default. Use IMPORT_USE_API=1 to POST via the API instead.
# IMPORT_USE_API=1
# IMPORT_LAT=49.2606
# IMPORT_LNG=-123.246
# IMPORT_DELAY_MS=400
# IMPORT_SCHOOL=ubc
# Skip fetching image_url when caption parse is incomplete (local file only)
# IMPORT_SKIP_IMAGE_URL=1

# Instagram scraper (Puppeteer)
IG_USERNAME=your-instagram-username
IG_PASSWORD=your-instagram-password
# Set to 'true' to run headless (default: false — opens a visible browser for login)
# IG_HEADLESS=false
